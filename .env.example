# igniter configuration — copy to `.env` and fill in for your host.
#
#   cp .env.example .env && edit .env
#   igniterctl status          # uses .env via your shell / `set -a; . ./.env`
#   docker run --env-file .env ghcr.io/<you>/igniter
#
# In Kubernetes these become the container's env (plain values for the
# non-secret ones; the *_PASSWORD / *_TOKEN_SECRET ones via a Secret —
# never commit real credentials). See deploy/ for example manifests.
#
# Everything is optional except IGNITER_HOST, IGNITER_POWER, and the chosen
# driver's required vars. Unset vars fall back to the defaults shown.

# ── core ─────────────────────────────────────────────────────────────────────
# A label for logs and the power intent (any string: e.g. host01, nas, gpu-box).
IGNITER_HOST=myhost

# Comma-separated k8s node names this host carries. igniter waits for them Ready
# + uncordons on power-on, and cordons + drains them on power-off. Leave empty
# for a bare host that runs no k8s nodes (power-only, no node lifecycle).
IGNITER_NODES=

# Per-node drain budget on wind-down, power-on -> all-nodes-Ready budget, and
# the budget for the power-off itself (soft-off -> verify -> hard-off fallback).
# Go durations (e.g. 90s, 5m, 12m). In k8s keep
# (IGNITER_DRAIN_TIMEOUT + ~2m) + IGNITER_POWEROFF_TIMEOUT under the pod's
# terminationGracePeriodSeconds.
IGNITER_DRAIN_TIMEOUT=5m
IGNITER_BOOT_TIMEOUT=12m
IGNITER_POWEROFF_TIMEOUT=5m

# Scale-down safety: igniter only powers OFF when its OWN Deployment desires 0
# replicas (a SIGTERM with replicas>=1 is a pod replacement, not a scale-down).
# In k8s, inject these from the downward API; locally they can stay unset
# (igniter then assumes "wanted" and never powers off — safe default).
IGNITER_DEPLOYMENT=
IGNITER_NAMESPACE=

# Which power driver to use: ipmi | wol | proxmox. Fill in ONLY that driver's
# block below.
IGNITER_POWER=wol

# ── driver: ipmi (BMC / iDRAC — soft-off, verified, hard-off fallback) ───────
# IGNITER_POWER=ipmi
IPMI_ADDR=                       # BMC host/IP, e.g. 10.0.0.50
IPMI_USER=root
IPMI_PASSWORD=                   # SECRET — from a k8s Secret in prod, not git
# Off sends an ACPI soft-off, waits IPMI_SOFT_GRACE for the host to actually go
# down, then escalates to a hard power-down (waiting IPMI_HARD_GRACE), polling
# every IPMI_POLL_INTERVAL. Defaults shown; usually fine to leave unset.
IPMI_SOFT_GRACE=3m
IPMI_HARD_GRACE=90s
IPMI_POLL_INTERVAL=15s

# ── driver: wol (consumer board: magic packet ON, verified SSH shutdown OFF) ─
# IGNITER_POWER=wol
WOL_MAC=                         # target NIC MAC, e.g. aa:bb:cc:dd:ee:ff
WOL_BROADCAST=255.255.255.255:9  # LAN broadcast:port for the magic packet
SSH_ADDR=                        # host:port for the shutdown command, e.g. host:22
SSH_USER=root
SSH_PASSWORD=                    # SECRET — set this OR SSH_KEY (key preferred)
SSH_KEY=                         # path to a PEM private key file, OR the inline PEM contents (alternative to SSH_PASSWORD; key preferred)
# Off runs `shutdown -h now`, waits WOL_SOFT_GRACE for the host to go offline,
# then makes a best-effort forced power-off over SSH (waiting WOL_HARD_GRACE),
# polling reachability every WOL_POLL_INTERVAL. Defaults shown.
WOL_SOFT_GRACE=3m
WOL_HARD_GRACE=90s
WOL_POLL_INTERVAL=15s

# ── driver: proxmox (PVE API token — per-VM start/verified shutdown) ─────────
# IGNITER_POWER=proxmox
PVE_URL=                         # API base, e.g. https://pve.lan:8006
PVE_TOKEN_ID=                    # e.g. igniter@pve!ci
PVE_TOKEN_SECRET=                # SECRET — the token's UUID secret
PVE_NODE=                        # PVE node name the VMs live on, e.g. pve
PVE_VMIDS=                       # comma-separated VMIDs to control, e.g. 105,106,107
# Off runs a graceful per-VM `shutdown`, waits PVE_SOFT_GRACE for them to stop,
# then hard `stop`s any straggler (waiting PVE_HARD_GRACE), polling VM status
# every PVE_POLL_INTERVAL. Defaults shown.
PVE_SOFT_GRACE=3m
PVE_HARD_GRACE=90s
PVE_POLL_INTERVAL=15s
